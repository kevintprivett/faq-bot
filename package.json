{
  "name": "faq-bot",
  "version": "0.0.1",
  "description": "simple faq bot for discord",
  "license": "MIT",
  "author": "Kevin Privett",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "wrangler types && tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:wrangler": "wrangler dev",
    "secrets": "wrangler secret bulk .env",
    "publish": "wrangler deploy",
    "register": "tsx src/register.ts",
    "type-check": "tsc --noEmit",
    "format": "prettier . --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "discord-api-types": "^0.38.47",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "wrangler": "^4.84.0"
  },
  "dependencies": {
    "discord-interactions": "^4.4.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.14"
  }
}
